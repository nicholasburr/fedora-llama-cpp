# ============================================================================
# fedora-llama-cpp Configuration File
# ============================================================================
# Copy this file to .env and customize for your system:
#   cp .env.example .env
#
# DO NOT commit .env to git (it is in .gitignore)
# ============================================================================

# ----------------------------------------------------------------------------
# PATH CONFIGURATION
# ----------------------------------------------------------------------------

# Model cache directory (where downloaded models are stored)
# Default: $HOME/.cache/huggingface/hub
MODEL_CACHE_DIR="${HOME}/.cache/huggingface/hub"

# Configuration directory (where models.yaml and configs live)
# Default: $HOME/.config/llama.cpp
CONFIG_DIR="${HOME}/.config/llama.cpp"

# Scripts directory (where hf-download.sh and other scripts are located)
SCRIPTS_DIR="containers/files"

# ----------------------------------------------------------------------------
# CONTAINER CONFIGURATION
# ----------------------------------------------------------------------------

# Container registry prefix (default: localhost)
CONTAINER_REGISTRY="localhost"

# Container runtime (podman or docker)
CONTAINER_RUNTIME="podman"

# ----------------------------------------------------------------------------
# SECRET CONFIGURATION
# ----------------------------------------------------------------------------

# Hugging Face token (optional)
HF_TOKEN=""

# vLLM API key (optional)
VLLM_API_KEY=""

# ----------------------------------------------------------------------------
# DEBUG CONFIGURATION
# ----------------------------------------------------------------------------

# Enable debug logging (set to 1 to enable)
CONFIG_DEBUG="0"

# Show container commands without executing (set to 1 for dry-run)
DRY_RUN="0"
